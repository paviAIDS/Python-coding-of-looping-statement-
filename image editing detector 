import gradio as gr
from PIL import Image, ImageChops, ImageEnhance
import piexif

# Function for Metadata check
def has_metadata(img_path):
    try:
        exif_dict = piexif.load(img_path)
        return len(exif_dict.get("0th", {})) > 0
    except Exception:
        return False

# Function for ELA
def error_level_analysis(img_path, quality=90):
    img = Image.open(img_path).convert("RGB")
    temp_path = "temp.jpg"
    img.save(temp_path, "JPEG", quality=quality)
    compressed = Image.open(temp_path)

    diff = ImageChops.difference(img, compressed)
    extrema = diff.getextrema()
    max_diff = max([ex[1] for ex in extrema])
    scale = 255.0 / max_diff if max_diff != 0 else 1
    diff = ImageEnhance.Brightness(diff).enhance(scale)

    return diff

# Main function for Gradio
def detect_images(imageA, imageB):
    metaA = has_metadata(imageA)
    metaB = has_metadata(imageB)

    elaA = error_level_analysis(imageA)
    elaB = error_level_analysis(imageB)

    # Simple scoring
    scoreA = 1 if metaA else 0
    scoreB = 1 if metaB else 0

    elaA_brightness = sum(elaA.getextrema()[0]) / 2
    elaB_brightness = sum(elaB.getextrema()[0]) / 2

    if elaA_brightness < elaB_brightness:
        scoreA += 1
    else:
        scoreB += 1

    if scoreA > scoreB:
        result = "✅ Image A is likely ORIGINAL\n❌ Image B is likely EDITED"
    elif scoreB > scoreA:
        result = "✅ Image B is likely ORIGINAL\n❌ Image A is likely EDITED"
    else:
        result = "🤔 Cannot decide confidently"

    return elaA, elaB, result

# Launch Gradio
iface = gr.Interface(
    fn=detect_images,
    inputs=[gr.Image(type="filepath", label="Upload Image A"),
            gr.Image(type="filepath", label="Upload Image B")],
    outputs=[gr.Image(label="ELA of Image A"),
             gr.Image(label="ELA of Image B"),
             gr.Textbox(label="Final Decision")],
    title="Edited Image Detector",
    description="Upload an Original and an Edited image. The system will analyze metadata + ELA to decide which is more likely original."
)
app.launch(inline=True)






